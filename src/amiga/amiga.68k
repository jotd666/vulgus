	.include	"ReadJoypad.i"
	.include	"whdload_funcs.i"
		.text

	.macro	BKPT comment
	move.l	a0,-(a7)
	lea		comment\@(pc),a0
	move.b	#0,0x110
	move.l	(a7)+,a0
	jra		next\@
comment\@:
	.asciz	"\comment"
	.align	2
next\@:
	.endm

	    
_user:
    * if D0 contains "WHDL"
    * A0 contains resload
        
    cmp.l   #0x05748444c,D0	| WHDL
    bne.b   .standard
	move.b	d1,_keyexit
    move.l a0,_resload

	move.l	a0,a2
	lea	(_tag,pc),a0
	jsr	(resload_Control,a2)
	
    bra		.no_forbid
.standard:
	
    * open dos library, graphics library
    move.l  0x4.W,a6
    lea dosname,a1
    moveq.l #0,d0
    jsr _LVOOpenLibrary(a6)
    move.l  d0,_dosbase

	lea	read_args_string(pc),a0
	lea	program_args(pc),a1
	move.l	#program_args_end-program_args,d0
	lsr.l	#2,d0		| number of longs
	

	bsr	get_args_BCPL

0:	
	lea		program_args,a0

	move.l	(A0)+,D0	| INVINCIBLE/S
	beq.b	1f
	or.l	#1,cheat_flags
	st.b	cheat_used
1:
	move.l	(A0)+,D0	| INFLIVES/S
	beq.b	2f
	or.l	#2,cheat_flags
	st.b	cheat_used
2:
	move.l	(A0)+,D0	| CHEATKEYS/S
	beq.b	2f
	* cheat isn't used as long as no cheat key is used
	or.l	#0x10,cheat_flags
2:



	lea		_custom,a5
	lea		debug_copperlist,a0
	move.l	a0,cop1lc(a5)

* no multitask
	
	move.l	4.W,A6
	* system-friendly PAL/NTSC detect
	cmp.b #50,0x212(a6)		| vblankfrequency
	jeq	0f
	* set NTSC
	move.l	#NTSC_MONITOR_ID,monitor
0:
	lea graphicsname,a1
    moveq.l #0,d0
    jsr _LVOOpenLibrary(a6)
    move.l  d0,_gfxbase
    move.l	d0,a6
	move.l	38(a6),old_syscoplist
	move.l	34(A6),old_actiview		| gb_ActiView

	sub.l	a1,a1
	jsr	_LVOLoadView(a6)
	jsr	_LVOWaitTOF(a6)
	jsr	_LVOWaitTOF(a6)
	
	*jbsr		load_highscores
    * check if "floppy" file is here
    move.l  _dosbase(pc),a6
    move.l   #floppy_file,d1
    move.l  #1005,d2   | MODE_OLDFILE
    jsr     _LVOOpen(a6)
    move.l  d0,d1
    beq.b   .no_floppy
    * "floppy" file found
    jsr     _LVOClose(a6)
    * wait 2 seconds for floppy drive to switch off
    move.l  #100,d1
    jsr     _LVODelay(a6)
.no_floppy:

* no multitask
	
    move.l  4,a6
    jsr _LVOForbid(a6)

    
	sub.l	A1,A1
	jsr	_LVOFindTask(a6)		| find ourselves
	move.l	D0,A0
	move.l	#-1,184(A0)	| pr_WindowPtr: no more system requesters (insert volume, write protected...)

.no_forbid:
	.ifne	OPT_ENABLE_LOGGING
	* protection for end of cpu log buffer
	lea		log_buffer_end,a0
	move.l	#0xCAFECAFE,d0
	.rept	4
	move.l	d0,(a0)+
	.endr
	.endif


	* dummy copperlist with no bitplanes enabled
	lea		_custom,a5
	lea		debug_copperlist,a0
	move.l	a0,cop1lc(a5)
	
	jbsr	apply_settings

	jbsr	 _detect_controller_types


	
	jra		demo_game

apply_settings:
	
	move.l	cheat_flags,d0
	jeq		1f
	btst	#0,d0
	sne		invincible_flag
	btst	#1,d0
	sne		infinite_lives_flag
	move.b	d0,d1
	and.b	#3,d1
	jeq		2f
	* cheat key disable highscore only if used
	st.b	cheat_used
2:


0:
1:	
	* default is 25Hz
	move.l	misc_options,d1
	btst	#0,d1
	seq		frameskip
	btst	#1,d1
	sne		disable_long_fire_press_flag




	move.l	cheat_flags,d0
	btst	#0,d0
	beq.b	0f
	st		cheat_used
0:
	btst	#1,d0
	beq.b	0f
	st		cheat_used
0:
	btst	#2,d0
	beq.b	0f
	st		cheat_used
0:
	move.l	cheat_flags,d0
	btst	#3,d0
	beq.b	0f
	st		cheat_used

0:

0:
	* set dip switches
	* (some settings are not modifiable)
	moveq	#0,d0

	move.b	start_level+3,d1
	and.w	#3,d1
	or.w	d1,d0
	
	move.b	start_lives+3,d1
	lea		lives_table,a0
	and.w	#3,d1
	or.b	(a0,d1.w),d0
	
	not.b	d0
	move.b	d0,dip_switches_1


	moveq	#0,d0
	
	lea		difficulty_table,a0
	move.b	difficulty_level+3,d1
	and.w	#1,d1
	move.b	(a0,d1.w),d1
	lsl.b	#4,d1
	or.b	d1,d0
	not.b	d0
	move.b	d0,dip_switches_2
	rts

display_text:
	move.l	a0,-(a7)
0:
	move.b	(a1)+,d1
	jmi		1f
	move.b	d1,(a0)
	move.b	d0,(0x400,a0)
	jbsr	osd_video_byte_dirty
	addq	#1,a0
	jra		0b
1:
	move.l	(a7)+,a0
	rts

	.ifndef	RELEASE
	
* < A1: address
* < D0: number
num2hexstring:
	movem.l	d0-a6,-(a7)
	moveq	#3,d4		| nb digits
	move.l	#0xF000,D3
	moveq.l	#4,D2
	move.b	#'x',(A1)+	
.loop:
	move.w	D0,D1
	and.w	D3,D1
	rol.w	D2,D1
	cmp.b	#9,D1
	bgt	.letter
	**add.b	#'0',D1		| in this charset no need to add '0'
	move.b	D1,(A1)+
	bra	.loopend
.letter:
	add.b	#'A'-10,D1
	move.b	D1,(A1)+
.loopend:
	addq.l	#4,D2
	lsr.l	#4,D3
	dbf	D4,.loop
	st.b	(a1)
	movem.l	(a7)+,d0-a6
	rts
	
* < A0: address
* < D0: color
* < D1: value 16 bit
display_number:
	lea		(-8,a7),a7
	move.l	a7,a1
	exg	d0,d1
	jbsr	num2hexstring
	exg	d0,d1
	jbsr	display_text
	lea		(8,a7),a7
	rts
	
	
	.endif
	
* so memory is quadword-aligned (not trusting .align directives)
align_for_fmode:
	.ifne	OPT_AGA_MODE
	add.w	#0x8,a0
	move.l	a0,d0
	and.b	#0xF8,d0
	move.l	d0,a0
	.endif
	rts
	
* < D0: bcpl string (with leading size byte)
* < A1: dest C string
bcpl_arg_string_copy:
    movem.l D0-D2/A0-A1,-(a7)
	lsl.l	#2,d0
	moveq.l	#0,d2
    move.l  d0,a0
	move.b	(a0)+,d2	| size
	beq.b	1f
	subq	#1,d2
0:
	move.b	(a0)+,(a1)+
	dbf		d2,0b
1:
    movem.l (a7)+,D0-D2/A0-A1
    rts


bcpl_string_to_int:
    movem.l A0/A1,-(a7)
    lea temp_filename_buffer(pc),a1
    bsr bcpl_arg_string_copy
    * convert to integer
    move.l  a1,a0
    * < A0: pointer on C string
    * > D0: value
    * > D1: -1 if ok, position of the string if error
    bsr parse_integer
    movem.l  (a7)+,a0/a1
	rts
	
* parse integer from string
* < A0: pointer on C string
* > D0: value
* > D1: -1 if ok, position of the string if error
parse_integer:
    movem.l  d2/d3,-(a7)
    * go to end of string
    moveq.l #-1,d1
.loop1:
    addq.l  #1,d1
    tst.b   (a0,d1.w)
    bne.b   .loop1
    * d1 is the number of chars
    moveq.l #0,d0
    moveq.l #0,d2
    subq.l  #2,d1   | 10th power minus 1
.loop2:
    move.b  (a0)+,d2
    beq.b   .out
    
    cmp.b   #32,d2
    beq.b   .sk
    sub.b   #48,d2
    bcs.b   .error
    cmp.b   #10,d2
    bcc.b   .error
    move.w  d1,d3
    bmi.b   .doadd
.muloop:
    mulu    #10,d2
    dbf d3,.muloop
.doadd:
    add.l   d2,d0
.sk:
    subq.l  #1,d1
    bra.b   .loop2
.out:    
    movem.l  (a7)+,d2/d3
    rts
.error:
    moveq.l #0,d0
    bra.b   .error
	
    * thanks Toni for this 1.3 read argument code
BCPL_RdArgs = 78
	
	* a1 = pointer to result array. Must be LONG aligned!
	* a0 = formatting string. BSTR!
	* d0 = size of result array (number of LONGs)
get_args_BCPL:
	movem.l d2/d3/d4,-(sp)
	move.l d0,d3
	moveq #BCPL_RdArgs,d0
	move.l a0,d1
	lsr.l #2,d1
	move.l a1,d2
	lsr.l #2,d2
	moveq #0,d4
	bsr.s call_bcpl
	movem.l (sp)+,d2/d3/d4
	rts

	* d0 = gv index
	* d1-d4 = bcpl parms

BCPL_STACK = 3000

call_bcpl:
	movem.l d2-d7/a2-a6,-(sp)

	move.l d0,d6
	move.l d1,d5

	move.l 4.w,a6
	move.l	_dosbase(pc),a5


	sub.l a1,a1
	jsr	_LVOFindTask(a6)
	move.l d0,a4

	* allocate BCPL stack
	move.l #BCPL_STACK,d0
	move.l #65536+1,d1
	jsr	_LVOAllocMem(a6)
	move.l d0,d7
	beq.s 0f
	
	movem.l d7/a5/a6,-(sp)

	moveq #0,d0
	move.l d5,d1
	sub.l a0,a0
	move.l d7,a1
	lea 3*4(a1),a1
	move.l 136(a4),a2
	add.w	d6,d6
	add.w	d6,d6
	move.l 0(a2,d6.w),a4
	movem.l 46(a5),a5/a6
	jsr (a5) | call bcpl!
	
	movem.l (sp)+,d7/a5/a6

0:
	move.l d7,a1
	move.l #BCPL_STACK,d0
	jsr	_LVOFreeMem(a6)


	movem.l (sp)+,d2-d7/a2-a6
	rts




demo_game:
		move		#0x4000,_custom+intena						| disable interrupts
		move		#0x7FFF,_custom+intreq						| ack all interrupts
		bsr			platform_init					| amiga-specific init
		
0:	
	.ifne	OPT_ALIGNED_MEMORY
	* compute ram start for dev mode
	* align so real addresses LSW match actual arcade addresses
	* and lower 16-bit match original RAM & even ROM offsets
	*

	lea		dev_ram_buffer,a6
	move.l	a6,d0
	clr.w	d0
	move.l	d0,d1
	add.l	#0x10000,d1
	move.l	d1,rom_start_0000		| memory (0x0000-0xFFFF)
	
	* copy the ROM data
	move.l 	d1,a1
	move.w	#ROM_SIZE/4-1,d0
	.else
	* release mode

	* copy the ROM data after RAM
	lea		rom_buffer,a1
	move.w	#ROM_SIZE/4-1,d0
	.endif
	
	lea		rom_base,a0
0:
	move.l	(a0)+,(a1)+
	dbf		d0,0b

	
	GET_MEMORY_START_IN_A6
	
	*lea 	(vulgus_hi_score_018f,a6),a0
	*jbsr	osd_read_high_scores
	
	.ifndef	RELEASE
	* install dump and quit handler
	tst.l	_resload
	jeq		0f
	pea		dump_and_quit
	lea		2.W,a0
	move.l	#0x4AFC4EF9,(a0)+
	move.l	(a7)+,(a0)+
	* protect ROM from writing if whdload on
	move.l	#0xC000,d0
	move.l	a6,a0
	move.l  (_resload,pc),a2
	jsr     (resload_ProtectWrite,a2)
	* protect graphics area: it doesn't work
	move.l	#end_tables,d0
	lea	fg_character_table,a0
	sub.l	a0,d0
	move.l  (_resload,pc),a2
	*jsr     (resload_ProtectWrite,a2)
0:
	.endif
	

	* enable interrupts. Game doesn't use them
	* but relies on vbl sync flags
	
	jbsr	cache_fg_tiles_address
	jbsr	cache_bg_tiles_address

	

	* install game irq handler
	move.l	system_vbr(pc),a1
	pea		level1_interrupt(pc)
	move.l	(a7)+,(0x64,a1)


	GET_MEMORY_START_IN_A6	
	jbsr	cpu_init		| zero most registers
	jbsr	hw_init
	jmp		reset_0000								| pass control to the mpatrol core
	
hw_init:
	move.l	a6,a0
	add.l 	#0xC000,a0
	st.b	(system_c000-0xC000,a0)
	st.b	(port_1_c001-0xC000,a0)
	st.b	(port_2_c002-0xC000,a0)
	move.b	dip_switches_1,(dsw1_c003-0xC000,a0)
	move.b	dip_switches_2,(dsw2_c004-0xC000,a0)

	rts
	
* zero all registers
cpu_init:
	moveq	#0,d0
	moveq	#0,d1
	moveq	#0,d2
	moveq	#0,d3
	moveq	#0,d4
	moveq	#0,d5
	moveq	#0,d6
	moveq	#0,d7
	* IX/IY are on top of mem at start
	move.l	a6,a2
	add.l	#0xFFFF,a2
	move.l	a2,a3
	rts
	



	.ifndef	RELEASE
dump_and_quit:	
	jbsr	osd_dump_logs
	illegal
	.endif

osd_set_palette_bank:
	move.w	d0,-(a7)
	and.b	#3,d0
	cmp.b	current_palette_bank,d0
	jeq		0f
	move.b	d0,current_palette_bank
	* we can't refresh immediately, sometimes (shining stars) the game
	* changes bank at each frame, requiring screen full redraw
	move.b	#50,refresh_countdown
0:
	move.w	(a7)+,d0
	rts

refresh_bg_tiles:
	* refresh bg tiles completely
	GET_MEMORY_START_IN_A6
	move.l 	a6,a0
	add.l	#bg_tiles_address_d800,a0
	move.w	#0x3FF,d7
1:
	jbsr	osd_video_byte_dirty
	addq	#1,a0
	dbf		d7,1b
0:
	rts
	

	


	
	
* < A0: filename
* < A1: buffer
* < D0: max size
load_file:
	move.l	_resload,d1
	jeq		0f
	move.l	d1,a2
	movem.l	d0-d3/a0/a1,-(a7)
	move.l	d0,d2		| store max size
	move.l	a0,d3		| store filename
	jbsr	resload_GetFileSizeDec(a2)
	.ifndef	RELEASE
	cmp.l	d0,d2
	jcc		0f
	BREAKPOINT	"file size too big vs buffer. D0=size, D2=max, D3=filename"
0:
	.endif
	movem.l	(a7)+,d0-d3/a0/a1
	
	jbsr	resload_LoadFileDecrunch(a2)
	rts
0:
	illegal
	
call_nmi:
	* reset most registers
	jbsr	cpu_init
	* set base for RAM
	GET_MEMORY_START_IN_A6
	
	jra	vblank_isr_01b0
	
* <D0,D1 current & prev joy states

handle_long_fire_press:
	btst 	#JPB_BTN_RED,d0
	jeq		0f
	btst	#JPB_BTN_RED,D1
	jeq		0f
	* increase timer only if
	* - button is pressed
	* - button was pressed
	* - timer is not above a given value, which is the grenade
	*   trigger value plus one (so it locks until fire is released)
	move.b	long_fire_timer,d3
	cmp.b	#LONG_FIRE_TIMER_VALUE+1,d3
	jeq		1f		| maxxed out
	addq.b	#1,d3
	move.b	d3,long_fire_timer
	cmp.b	#LONG_FIRE_TIMER_VALUE,d3
	jne		1f
	* exact value: trigger grenade
	bset	#JPB_BTN_BLU,d0
	move.l	d0,joypad_1_state
	rts
0:
	clr.b	long_fire_timer
1:
	rts
	
* just in case some hardware calls nmi
_nmi:
	move.w	#0x7FFF,_custom+intreq
	move.w	#0x7FFF,_custom+intreq
	rts
	
level3_interrupt:
	movem.l d0-d7/a0-a6,-(a7)
	lea		_custom,a5
	move.w	(intreqr,a5),d0
	btst	#5,d0
	jeq		1f

	tst.b	detect_controllers
	jeq	0f
	clr.b	detect_controllers
	jbsr	 _detect_controller_types_nowait

0:


	move.l	joypad_1_state(pc),d1
	moveq	#1,d0
	jbsr	_read_joystick
	move.l	d0,joypad_1_state
	tst.b	disable_long_fire_press_flag
	jne		0f
	jbsr	handle_long_fire_press
0:	
	GET_MEMORY_START_IN_A6
	move.l	d1,d2		| save prev state
	jbsr	update_controls

	jbsr	read_system
	
	move.l	joypad_1_state,d0
	btst	#JPB_BTN_PLAY,d0
	beq.b	0f
	btst	#JPB_BTN_PLAY,d2
	bne.b	0f
	jbsr		toggle_pause
0:

	
	* ack vbl twice (040/pistorm bug)
	move.w	#0x20,(intreq,a5)
	move.w	#0x20,(intreq,a5)	
	jra	3f
1:
	.ifndef	RELEASE
	btst	#6,d0
	jne		2f
	BREAKPOINT	"unexpected level 3 interrupt"
2:
	.endif
	* has to be blitter operation completed: handle next blit
	* ack blitter int twice (040/pistorm bug)
	move.w	#0x40,(intreq,a5)
	move.w	#0x40,(intreq,a5)	

	
	PROCESS_ONE_BLIT

3:
    movem.l (a7)+,d0-d7/a0-a6
    rte


level1_interrupt:
 	.ifndef	RELEASE
	move.l	(2,a7),interrupted_code_pc
	.endif
	* disable osd context switch
	* we MUST NOT change d5 or change stack from an osd call from an interrupt
	addq.b	#1,osd_entry_count
    movem.l d0-d7/a0-a6,-(a7)
	lea		_custom,a5
	move.w	(intreqr,a5),d0		| leave this, we need it for later on
	* we're going to ack copper & software level 1 interrupt now
	* do it twice (040/pistorm bug)
	.rept	2
	move.w	#0x14,(intreq,a5)
	.endr


	tst.b	pause_flag
	jne	23f


	* declare that we're in interrupt mode so osd_disable_interrupts/osd_enable_interrupts
	* is level 1 interrupt set? that would mean that mid-screen interrupt
	* is the source of the interrupt
	btst	#4,d0
	beq.b	2f
	* mid-screen copper interrupt, must occur once every 5 times
	* to simulate ~60 Hz on 50 Hz display
	move.b	mid_screen_interrupt_count,d0
	addq.b	#1,d0
	cmp.b	#5,d0
	bne.b	1f
	jbsr	call_nmi
	clr.b	d0
1:
	move.b	d0,mid_screen_interrupt_count
	jra		3f	| no need to update sprites we're in the middle of a frame
2:


	jbsr	call_nmi

	GET_MEMORY_START_IN_A6
	
	* compute current values of scrolling
	* m_bg_tilemap->set_scrollx(0, m_scroll_low[1] + 256 * m_scroll_high[1]);
	* m_bg_tilemap->set_scrolly(0, m_scroll_low[0] + 256 * m_scroll_high[0]);

	moveq	#0,d0
	move.b	(scroll_high_c902,a6),d0   | high
	ror.w	#8,d0		| hardware is in little endian
	move.b	(scroll_low_c802,a6),d0   | low
	move.w	D0,game_scroll_x
	move.b	(scroll_high_c902+1,a6),d0   | high
	ror.w	#8,d0		| hardware is in little endian
	move.b	(scroll_low_c802+1,a6),d0   | low
	add.w	#0x100,d0	| 0: bottom part
	and.w	#0x1FF,d0
	neg.w	d0
	add.w	#0x1FF,d0
	move.w	D0,game_scroll_y
	
	move.b	refresh_countdown,d0
	jeq		0f
	subq.b	#1,d0
	move.b	d0,refresh_countdown
	jne		0f
	jbsr	refresh_bg_tiles
0:

	tst.b	frameskip
	jeq		0f
	eor.b	#1,flip_flop
	jeq		23f
0:
	* wait for blits to complete (via soft flag that last blitter command
	* sets when reaching the end of the list) and reset list pointers
	NEW_BLITLIST
	
	* In sync blitter, the ball is drawn, then buffers are switched
	* and current scroll makes up for ball moving in the opposite direction perfectly.
	*
	* In async blitter (OPT_BLIT_CHAIN_MODE==1), we use the scroll value stored in the blitter command list
	
	* show the newly drawn buffer THEN switch the buffers
	* problem: frames and scroll values aren't in sync, this is visible when
	* the ball crosses the screen, this is because we're now displaying what's been drawn
	* at the previous frame. 

	
	.if		OPT_BLIT_CHAIN_MODE==1
	jbsr	set_bobs_bitplanes
	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	jbsr		switch_screen_buffers
	.endif

	lea		_custom,a5
	* start the chain reaction
	tst.b	size_command_issued
	jne		0f
	* size command not issued: set blitter scrolling immediately
	* no risks of bob shifting, there are no bobs on screen
	*move.l	scroll_x_hi,blitter_scroll_x
	*move.w	scroll_y,blitter_scroll_y
	jra		1f
0:
	.endif
	FORCE_PROCESS_BLITS
1:
	* fill the blitter command list while blitter interrupt 
	* is processing the other blitter command list
	* first fix the scrolling, so when it is set at the next frame, it is still coherent
	* with the shifting that we put on BOBs to follow it (original game doesn't need that
	* it has a separate layer for sprites, we just have crap dual playfield we cannot use here)

	*WRITE_BLITTER_SCROLL_VALUES		scroll_x_hi,scroll_y FUCK
	*jbsr		really_update_sprites
	* terminate the blitter command list
	COMMIT_BLITLIST

	.if		OPT_BLIT_CHAIN_MODE==0
	jbsr		really_update_sprites

	.ifne	OPT_ENABLE_DOUBLE_BUFFERING
	jbsr		switch_screen_buffers
	.endif
	jbsr	set_bobs_bitplanes
	.endif
	
	.ifndef	RELEASE
	tst.b	osd_debug_active
	jeq		0f
	.set	row,2
	GET_MEMORY_START_IN_A6
	move.b	#2,current_color
	WRITE_TEXT	scrollx_text,0
	WRITE_TEXT	scrolly_text,0
	WRITE_TEXT	hscrollx_text,0
	WRITE_TEXT	last_x_offset_text,0
	move.b	#4,current_color
	WRITE_TEXT	debug_1_text,0
	WRITE_TEXT	debug_2_text,0
	WRITE_TEXT	debug_3_text,0

	.set		row,2
	move.b	#3,current_color
	WRITE_HEX	game_scroll_x
	WRITE_HEX	game_scroll_y
	lea		display_slots,a2
	tst.b	(a2)
	jeq		10f
	move.w	(2,a2),d0
	move.w	(a6,d0.w),d0
	WRITE_HEX	d0
	.set	row,row-1	
10:
	.set	row,row+1	
	addq	#4,a2
	tst.b	(a2)
	jeq		10f
	move.w	(2,a2),d0
	move.w	(a6,d0.w),d0
	WRITE_HEX	d0
	.set	row,row-1		
10:
	.set	row,row+1	
	addq	#4,a2
	tst.b	(a2)
	jeq		10f
	move.w	(2,a2),d0
	move.w	(a6,d0.w),d0
	WRITE_HEX	d0
	.set	row,row-1		
10:
	
	
0:
	.endif
	
	
	lea	_custom,a5
	move.w	(intreqr,a5),d0
	btst	#2,d0
	jeq		23f
	* interrupt arrived during this interrupt: this is taking too long
	* so skip the refresh
	move.b	#1,flip_flop
23:
	.ifne	OPT_ENABLE_LOGGING
	move.b	current_palette_bank,d0
	move.w	d0,-(a7)
	clr.b	current_palette_bank
	jbsr	log_used_fg_tiles
	move.w	(a7)+,d0
	move.b	d0,current_palette_bank
	
	jbsr	log_used_bg_tiles
	jbsr	log_used_sprites
	.endif
3:
    movem.l (a7)+,d0-d7/a0-a6
	* enable osd context switch
    subq.b	#1,osd_entry_count
 	.ifndef	RELEASE
	move.l	d0,-(a7)
	move.l	(6,a7),d0
	cmp.l	interrupted_code_pc,d0
	jeq		4f
	BREAKPOINT	"interrupt PC value changed!"
4:
	move.l	(a7)+,d0
	.endif
    rte
	
	
	
osd_blitz:
	blitz
	rts

osd_break:
	* sends a WinUAE command to enter WinUAE debugger
	.ifndef	RELEASE
	tst.l	_resload
	jeq		1f
* wait for VBL, so when breakpoint is hit, the DMA has displayed the current picture
	move.l	D0,-(a7)
	move.l	a0,-(a7)
	move.w	SR,-(a7)
	* block interrupts during the vblank wait
	* in dev mode, we use whdload in supervisor mode so SR can be written to
	move.w	#0x2700,SR
	lea	_custom,a0
	.rept	2
	move.w	#0x7FFF,intreq(a0)
0:
	move.w	intreqr(a0),d0
	btst	#5,d0
	beq.b	0b
	.endr
	move.w	(a7)+,sr
	move.l	(a7)+,a0
1:
	pea     0.w
	* Normally it would point to where the result of the command is written, but since the last parameter (first pushed)
	* indicating the number of bytes to write is 0, nothing is written.
	pea     0.w	
	pea     1003f-1002f
	pea     1002f(pc)
	pea     -1.w
	pea     82.w
	jsr     0xf0ff60
	lea     24(sp),sp
	move.l	(a7)+,d0
	.endif
    rts
		
1002: .asciz    "AKS_ENTERDEBUGGER 1"
1003:
        .align	2

* < D0: number of 1/60Hz ticks
* can work with interrupts enabled or disabled
osd_wait:
	move.w	d0,delay_timer
	**jbsr	osd_is_vblank_interrupt_enabled
	tst.w	d0
	jne		2f
	* interrupts are disabled: timer isn't going to change
	* wait using vertical blank interrupt request (we don't need it!)
	clr.w	one_out_of_five
0:
	move.w	#0x20,_custom+intreq
	move.w	#0x20,_custom+intreq
1:
	move.w	_custom+intreqr,d0
	btst	#5,d0
	beq.b	1b
	addq.w	#1,one_out_of_five
	cmp.w	#5,one_out_of_five
	bne.b	5f
	subq.w	#1,delay_timer	
	clr.w	one_out_of_five
5:
	subq.w	#1,delay_timer
	beq.b	4f
	bpl.b	0b
4:
	rts
	
2:
	tst.w	delay_timer
	bne.b	2b
	rts

add_to_score:
	movem.l	a6/d0-d3,-(a7)
	GET_MEMORY_START_IN_A6
	move.l	a6,a0
	*add.l	#player_score_address_e0a6,a0
	move.w	(a0),d0
	rol.w	#8,d0
	lea		(a6,d0.w),a0	| current player score address
	
	moveq	#0,d0
	abcd 	d0,d0		| clear X

	move.b	(1,a0),d0
	move.b	(a0),d1
	move.b	#0x10,d3		| 10000 points
	abcd	d3,d0
	jcc		0f
	moveq	#0,d3
	abcd	d3,d1

0:
	move.b	d0,(1,a0)
	move.b	d1,(a0)
	movem.l	(a7)+,a6/d0-d3
	rts

lose_all_lives:
	movem.l	a6/d0-d3,-(a7)
	GET_MEMORY_START_IN_A6
	add.l	#0xE000,a6
*	move.b	#1,(nb_lives_eda0-0xE000,a6)
*	move.b	#0x3F,(player_state_e100-0xE000,a6)
	movem.l	(a7)+,a6/d0-d3
	rts

	
* Z: set if playing
is_game_playing:
	movem.l	d0/a6,-(a7)
	GET_MEMORY_START_IN_A6
	moveq	#0,d0
1:
	movem.l	(a7)+,d0/a6
	rts

	
* what: blits data on bg plane, no horizontal shifting (erase)
* args:
* < A0: pristine background
* < A1: dest buffer
* < D0: X (rounded to smaller 8-multiple)
* < D1: Y
* < D2: width in bytes
* < D4: height

* trashes: D0-D1

blit_background:
	movem.l	d2-d6/a0-a5,-(a7)
	lea		_custom,a5
	* adjust offset X: X//8
	lsr.w	#3,d0
	lea		mulBG_NB_BYTES_PER_ROW_table(pc),a4
	.ifndef	MC68020
	add.w	d1,d1
	* add Y offset: Y*NB_BYTES_PER_ROW
	add.w	(a4,d1.w),d0
	add.w	(a4,d1.w),d0
	.else
	add.w	(a4,d1.w*2),d0
	.endif
	* same offset for source and destination
	add.w	d0,a1
	add.w	d0,a0

    move.l  #0x09f00000,d3    | A->D copy, ascending mode	
	move.w	#BG_NB_BYTES_PER_ROW,d1		| blit modulo
	move.l	#BG_SCREEN_PLANE_SIZE,d0	| pre-load

    sub.w   d2,d1       | blit modulo
 	move.w	d4,d6		| save height
	subq	#1,d6       | for cpu restore mode
    lsl.w   #6,d4
	lea		copy_function_table,a4
	add.w	(a4,d2.w),a4	| pick proper erase func (4,6,8 width are the only cases here)
    lsr.w   #1,d2		| blit width
    add.w   d2,d4       | blit height
	
    * always the same settings

    * now just wait for blitter ready to write all registers
	WAIT_BLIT
    
    * blitter registers set

	WRITE_BLITTER_REG_LONG	d3,bltcon0	| sets con0 and con1

	WRITE_BLITTER_REG_WORD	d1,bltamod	|A modulo
	WRITE_BLITTER_REG_WORD	d1,bltdmod	|D modulo
							
	WRITE_BLITTER_REG_LONG	a0,bltapt	|source graphic top left corner
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
	
	* all bitplanes [but not the last one that we'll clear, not here, commented out!]
	
	.rept	NB_PLAYFIELD_PLANES-1
	.if	BG_SCREEN_PLANE_SIZE>0x7FFF
	add.l	d0,a0
	add.l	d0,a1
	.else
	add.w	d0,a0
	add.w	d0,a1
	.endif
	.ifeq	OPT_BLIT_CHAIN_MODE
	btst	#6,(dmaconr,a5)
	jeq		0f
	* if blitter is running, we'll use cpu copy instead. We cannot do it if we
	* attempt to use blitter interrupts of course
	jbsr 	(a4)
	jra		1f
0:
	.endif
	* other bitplanes
	WRITE_BLITTER_REG_LONG	a0,bltapt	|source graphic top left corner
	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top (bottom) left corner
	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
1:
	.endr
	
*	* last bitplane: just clear: just add to dest
*	.if	BG_SCREEN_PLANE_SIZE>0x7FFF
*	add.l	d0,a1
*	.else
*	add.w	d0,a1
*	.endif
*	
*	* reuse d1 for bltcon0
*	moveq	#1,d1
*	ror.l	#8,d1     | AKA move.l  #0x01000000,d1   | minterm useD & rect clear (0xA) 
*
*   * now just wait for blitter ready to write all registers
*	WAIT_BLIT
*    * last bitplane: clear
*	WRITE_BLITTER_REG_LONG	d1,bltcon0	
*	WRITE_BLITTER_REG_LONG	a1,bltdpt	|destination top left corner
*	WRITE_BLITTER_REG_SIZE	d4	|rectangle size, starts blit
	movem.l	(a7)+,d2-d6/a0-a5
	rts


copy_function_table:
	.word	copy_none-copy_function_table
	.word	copy_16-copy_function_table		| not reached here
	.word	copy_32-copy_function_table
	.word	copy_48-copy_function_table
	.word	copy_64-copy_function_table
	.word	copy_80-copy_function_table
	* probably never reached, just in case!
	.word	copy_none-copy_function_table
	.word	copy_none-copy_function_table

	.macro	CPU_COPY_PRE
	move.w	d6,d5
	move.l	a1,a3
	move.l	a0,a2
0:
	.endm
	.macro	CPU_COPY_POST
	add.w	d1,a2   | next row using modulus
	add.w	d1,a3
	dbf		d6,0b
	move.w	d5,d6
	rts	
	.endm
	

* should not be called
copy_none:
	.ifndef	RELEASE
	ILLEGAL
	.endif
	rts
	
copy_16:
	CPU_COPY_PRE
	move.w	(a2)+,(a3)+	
	CPU_COPY_POST
	
copy_32:
	CPU_COPY_PRE
	move.l	(a2)+,(a3)+	
	CPU_COPY_POST

copy_48:
	CPU_COPY_PRE
	move.l	(a2)+,(a3)+	
	move.w	(a2)+,(a3)+	
	CPU_COPY_POST

copy_64:
	CPU_COPY_PRE
	move.l	(a2)+,(a3)+	
	move.l	(a2)+,(a3)+	
	CPU_COPY_POST

copy_80:
	CPU_COPY_PRE
	move.l	(a2)+,(a3)+	
	move.l	(a2)+,(a3)+	
	move.w	(a2)+,(a3)+	
	CPU_COPY_POST



*	for (int offs = m_spriteram->bytes() - 4; offs >= 0; offs -= 4)
*	{
*		// bit 1 of attr is not used
*		int const attr = buffered_spriteram[offs + 1];
*		int const bank = (attr & 0xc0) >> 6;
*		int const code = buffered_spriteram[offs] + 256 * bank;
*		int const color = (attr & 0x30) >> 4;
*		int flipx = attr & 0x04;
*		int flipy = attr & 0x08;
