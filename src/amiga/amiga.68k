	.align	2
* < D0.W address of value to display (like this it is watched at each irq)
* < D1.W slot (0-3)
osd_display_value:
	movem.l	a0/d1,-(a7)
	lea		display_slots,a0
	and.w	#3,d1
	add.w	d1,d1
	add.w	d1,d1
	add.w	d1,a0
	st.b	(a0)
	move.w	d0,(2,a0)
	movem.l	(a7)+,a0/d1
	rts
	
display_slots:
	.long	0
	.long	0
	.long	0
	.long	0
	.endif
	
	.ifne	OPT_ENABLE_LOGGING

osd_get_last_known_pc:
	move.w	last_known_z80_pc,d7
	rts
	
	
* < D7: 0 disable, 1 enable, 2 reenable (restore state before disable)
* 2 is useful because you can 1) disable and 2) reenable
* if was not already enabled, reenable will do nothing
osd_cpu_logging_control:
	cmp.b	#2,d7
	jeq		1f
	* it's essential that we skip a second enable while active
	* or disable while inactive
	* else it kills the "reenable" feature, overwriting previous
	cmp.b	cpu_log_enable,d7
	jeq		2f		| enabled/disabled twice: skip
	* 0 or 1: save previous state	
	move.b	cpu_log_enable,cpu_log_prev_state
	move.b	d7,cpu_log_enable
	rts
1:
	* 2: reenable: put previous state, reenabling if needed
	move.b	cpu_log_prev_state,cpu_log_enable
2:
	rts
	
	.macro	CHECK_ADDRESS_IN_RANGE	reg
	move.l	a0,-(a7)
	move.l	\reg,a0
	sub.l	a6,a0
	cmp.l	#0x10000,a0
	jcs		0f
	move.w	(10,a7),d7
	BREAKPOINT	"\reg not in memory range check D7!"
0:
	move.l	(a7)+,a0
	.endm
	
	.macro	CHECK_ZERO_MSW	reg
	swap	\reg
	tst		\reg
	jeq		0f
	move.w	(6,a7),d7
	swap	\reg
	BREAKPOINT		"\reg MSW is not zero, PC=check d7!"
	jra		1f
0:
	swap	\reg
1:
	.endm


osd_log_cpu:
	CHECK_ZERO_MSW	d0
	* disabling others: push ix/pop bc briefly
	* triggers a problem
	*CHECK_ZERO_MSW	d1
	*CHECK_ZERO_MSW	d2
	*CHECK_ZERO_MSW	d3
	*CHECK_ZERO_MSW	d4
	*CHECK_ZERO_MSW	d5
	*CHECK_ZERO_MSW	d6

	CHECK_ADDRESS_IN_RANGE	a2
	CHECK_ADDRESS_IN_RANGE	a3
	
	movem.l	a2/a3/a5,-(a7)
	tst.w	(16,a7)
	jne		0f			| not cpu 0
	move.w	(18,a7),last_known_z80_pc
	move.w	last_known_z80_pc,0x100
	* check if cpu log is enabled
	tst.b	cpu_log_enable
	jeq		445f
	COLOR0_FLASH	0x0F0
	move.l	log_ptr,a5
	move.w	(18,a7),(a5)+	| the PC
	move.b	d0,(a5)+
	move.b	d1,(a5)+
	move.b	d2,(a5)+
	move.b	d3,(a5)+
	move.b	d4,(a5)+
	move.b	d5,(a5)+
	move.b	d6,(a5)+
	sub.l	a6,a2
	sub.l	a6,a3
	move.w	a2,(a5)+
	move.w	a3,(a5)+
	move.w	#0xDEAD,(a5)+
	cmp.w	#0xCAFE,(a5)  | hitting the protection buffer
	jne		444f
	* save log before hitting breakpoint
	movem.l	(a7)+,a2/a3/a5
	jbsr	save_cpu_log
	BREAKPOINT	"cpu log buffer full!"
	illegal
444:
	move.l	a5,log_ptr
445:
	movem.l	(a7)+,a2/a3/a5
	rts	


osd_dump_logs:
	OSD_ENTER
	move.w	sr,-(a7)
	move.w	#0x2700,SR
	movem.l	d0-a6,-(a7)
	
	jbsr	save_cpu_log

	move.l	_resload,a2
	lea		fg_tile_log_table,a1
	lea		fg_tile_log_name(pc),a0
	move.l	#FG_TILE_LOG_LENGTH,d0
	jbsr	resload_SaveFile(a2)
	
	lea		bg_tile_log_table,a1
	lea		bg_tile_log_name(pc),a0
	move.l	#BG_TILE_LOG_LENGTH,d0
	jbsr	resload_SaveFile(a2)
	
	lea		sprite_log_table,a1
	lea		sprite_log_name(pc),a0
	move.l	#SPRITE_LOG_LENGTH,d0
	jbsr	resload_SaveFile(a2)
	
	GET_MEMORY_START_IN_A6
	lea		(SPRITE_ADDRESS,a6),a1
	lea		sprite_mem_name(pc),a0
	move.l	#SPRITE_BUFFER_SIZE,d0
	jbsr	resload_SaveFile(a2)
	
	
    movem.l (a7)+,d0-a6
	move.w	(a7)+,SR
	OSD_EXIT
	rts


save_cpu_log:
	move.l	_resload,a2
	lea		log_buffer,a1
	move.l	log_ptr,d0
	sub.l	a1,d0
	jeq		0f
	move.l	log_ptr,a0
	* add RAM & ROM base in the end
	move.l	a6,(a0)+
	move.l	#rom_base,(a0)+
	addq	#8,d0
	lea		cpu_log_name(pc),a0
	jbsr	resload_SaveFile(a2)
0:	
	rts


