OPT_MIRROR_TEST = 0
	.else
OPT_ENABLE_LOGGING = 1
OPT_DEBUG_BANKSWITCH = 0
OPT_MIRROR_TEST = 0				| all sprites are mirrored
	.endif
	

OPT_ENABLE_DOUBLE_BUFFERING = 1

_custom = 0xDFF000

OPT_ENABLE_MULTIPLEXED_SPRITES = 0

	
	.if	NB_PLAYFIELD_PLANES>5
OPT_AGA_MODE=1
	.else
OPT_AGA_MODE=0
	.endif

FG_TILE_HEIGHT = 8
BG_TILE_HEIGHT = 16

* a plane of attached sprites	
NB_FG_PLANES = 4
NB_BG_PLANES = NB_PLAYFIELD_PLANES

TOTAL_NB_COLORS = 1<<NB_PLAYFIELD_PLANES
FG_NB_BYTES_PER_ROW = 0x20
BG_NB_BYTES_PER_ROW = 0x20

Y_START = 0x20

	.if	NB_PLAYFIELD_PLANES == 6
BASE_BPLCON2_VALUE = 0x0264			| killehb (we're using 6 real bitplanes) sprites above all playfields
	.else
BASE_BPLCON2_VALUE = 0x0064
	.endif

BASE_BPLCON4_VALUE = 0x0044	  | sprites palette starts at color 64

FG_NB_LINES = 256
BG_NB_LINES = 512+256
Y_MAX = 512+256
NB_PLAYFIELD_LINES = BG_NB_LINES


BG_SCREEN_PLANE_SIZE = BG_NB_BYTES_PER_ROW*BG_NB_LINES

