OPT_BLIT_CHAIN_MODE = 0		| enable blitter chaining
OPT_VBLIT_MIRROR_MODE = 1		| we need to mirror sprites on the fly, just before blitting them if needed
OPT_VBLIT_SCROLL_MODE = 1		| we need to store scrolling values else BOBs can shake



start:
	move.l	a7,old_stack
	jra		_user

	.include "../src/options.inc"
	
 
	
	.include "hardware/custom.i"
	.include "lvo/exec_lvos.i"
