NB_TARGET_SPRITES = 96

SPRITE_X = 2
SPRITE_Y = 3
SPRITE_CODE = 0
SPRITE_ATTRIBUTES = 1
SPRITE_SIZEOF = 4

BIT_COIN1 = 7
BIT_COIN2 = 6

BIT_START_1P = 0
BIT_START_2P = 1

BIT_UP = 3
BIT_RIGHT = 0
BIT_LEFT = 1
BIT_DOWN = 2
BIT_FIRE_1 = 4
BIT_FIRE_2 = 5

LONG_FIRE_TIMER_VALUE = 30
	
	.macro	COLOR0_FLASH	v
	.ifne	OPT_AGA_MODE
	move.w	#(BORDERBLANK<<5),_custom+bplcon3
	.endif
	move.w	#\v,_custom+color	
	.endm

	.macro	WRITE_TEXT	text,x_offset
	lea		\text,a1
	lea		(0x2047+\x_offset+0x20*row,a6),a0
	move.b	current_color,d0
	jbsr	display_text
	.set	row,row+1
	.endm

	.macro	WRITE_HEX	value
	move.w	\value,d1
	lea		(0x2047+0x20*row+14,a6),a0
	move.b	current_color,d0
	jbsr	display_number
	.set	row,row+1
	.endm
	
	* OSD ENTER/EXIT aren't useful for a Z80 game
	* as the code rarely uses the native stack to quick-read memory
	* (no multiple move like PULS/PSHS)
	
	.macro	OSD_ENTER
	.endm
	
	.macro	OSD_EXIT
	.endm
	
	

* exports

	.global		_user
	.global		_player_start
	.global		_resload
	.global		_dosbase
	.global		cheat_used
* osd layer		
	.global osd_enable_interrupts
	.global osd_disable_interrupts
	.global osd_set_tile_palette
	.global osd_break		| for debug	
	.global osd_blitz		| for debug
	
	.global	osd_video_byte_dirty
	

	*.global osd_read_high_scores
	.global osd_write_high_scores
	.global osd_set_palette_bank
	.global	load_highscores
	.global	save_highscores
	.global osd_sound_start
	.global osd_music_stop
	.global	force_sound_stop
	.global music_tick
	.global	music_track_start_number
	
	.global	osd_display_value
