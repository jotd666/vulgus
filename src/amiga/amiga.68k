	.long	0,0
	
blank_sound:
	ds.l	4
	
debug_copperlist:
	dc.w	bplcon0,0x200
	dc.w	color
debug_color:
	dc.w	0
	dc.l	-2
	


	
	* main copperlist
game_copperlist:
	* all sprites have the same palette no need to specify odd or even
	
	* black color background plane
	* enable sprite colors now
	.word	0x0601,0xFFFE
	
		

	
game_sprites:
	DECL_SPRITES
game_sprites_end:

copperlist_colors:
	.ifeq	OPT_AGA_MODE
	DECL_32_COLORS
	.else
	.set	bpl_count,0
	.rept	NB_PLAYFIELD_PLANES+1		| one more bank for sprites
	.word	bplcon3,(bpl_count<<13)+(BORDERBLANK<<5)
	.set	bpl_count,bpl_count+1
	DECL_32_COLORS
	.endr
	.endif

screen_start:
	.word	0x01+(0x20<<8),0xFFFE
bobs_bitplanes:
	DECL_BITPLANES	0,NB_PLAYFIELD_PLANES

	.word	bplcon1
fine_x_scroll_value:
	.word	0
	* here was first_rows (before I disabled it)
	* mid-line wait & extra interrupt
	.word	0x8001,0xFFFE
pal_intreq_block_game:
	.word	 intreq,0x8014  | call level 1 interrupt in the middle of a frame, also flag so copper interrupt knows that we're going to call copper int
	* here was second_rows (before I disabled it)
	
	
	* pal limit
	.if		OPT_AGA_MODE
    .word  0xFFCF,0xFFFE       | PAL wait 128 colors needs FFCF, FFDF fails
	.else
    .word  0xFFDF,0xFFFE       | PAL wait
	.endif
	* we have to perform several small waits else it doesn't wait
	* I don't want to know why, it works.
	.word	0x01+(0x04<<8),0xFFFE
	.word	0x01+(0x0C<<8),0xFFFE
	.word	0x01+(0x30<<8),0xFFFE


	
pal_wait:
	*.word	xxxx
	.word	 intreq,0x8004



     .long    -2					
	.ascii	"ENDCPLST"
	

	
	* aligning on 8 bytes so .align will work
	* in the next datachip sections
	.align	8
	
		.section .bsschip
		
		.ifne		OPT_SPRITE_MIRRORING
