	.include "sounds.inc"
	.include "data.inc"
	.include "utility_macros.inc"
	
AttnFlags = 0x128
AFB_68010 = 0
AFB_68020 = 1

*NO68020 = 1


NB_PLAYFIELD_PLANES = 6
	.ifndef	NB_PLAYFIELD_PLANES
	.error	"NB_PLAYFIELD_PLANES must be defined via --defsym"
	.endif



* proportional to the number of bitplanes
BLITTER_LIST_SIZE = 10000*NB_PLAYFIELD_PLANES
COPPER_NOP = 0x1FE

START_X = 0
START_Y = 0
BORDERBLANK = 1



PREVIOUS_SPRITE_SIZE = 10
CURRENT_SPRITE_SIZE = 4
COLUMN_SIZE = 0x20
ROW_SIZE = 0x20
GAME_MAX_SCROLL_X = 0x200
GAME_MAX_SCROLL_Y = 0x200
BG_TILE_WIDTH = 16


OPT_SPRITE_MIRRORING = 1

	
	.ifne		OPT_SPRITE_MIRRORING
MIRROR_BUFFER_SIZE = 0x15000
	.endif
	
SCORE_FILE_SIZE = 80

LOG_BUFFER_SIZE = 0x1000

FG_TILE_NB_CLUTS_POW = 6
FG_TILE_NB_CLUTS = 1<<FG_TILE_NB_CLUTS_POW
FG_TILE_COUNT = 0x200

BG_TILE_NB_CLUTS_POW = 7
BG_TILE_NB_CLUTS = 1<<BG_TILE_NB_CLUTS_POW
BG_TILE_COUNT = 0x200
SPRITE_COUNT = 0x100

SPRITE_NB_CLUTS_POW = 4
SPRITE_NB_CLUTS = 1<<SPRITE_NB_CLUTS_POW

HW_SPRITE_BUFFER_SIZE = (2*8*256+16*2)

SPRITE_LOG_LENGTH = SPRITE_COUNT*SPRITE_NB_CLUTS
FG_TILE_LOG_LENGTH = FG_TILE_NB_CLUTS*FG_TILE_COUNT
BG_TILE_LOG_LENGTH = BG_TILE_NB_CLUTS*BG_TILE_COUNT

SPRITE_X_CORRECTION = 0
SPRITE_Y_CORRECTION = -BG_TILE_WIDTH+1



* start displaying earlier in ntsc mode, allowing
* full display
NTSC_Y_SHIFT = 12

AGA_X_SHIFT = 0x37




FG_SCREEN_TILE_ADDRESS = fg_tiles_address_d000
FG_SCREEN_COLOR_ADDRESS = fg_tiles_color_address_d400
BG_SCREEN_TILE_ADDRESS = bg_tiles_address_d800
BG_SCREEN_COLOR_ADDRESS = bg_tiles_color_address_dc00

SPRITE_ADDRESS = 0xCC00  | to 0xCC7F
SPRITE_BUFFER_SIZE = 0x80

* if the alloc_sprite & update_sprite routines
* are reused, changing those offsets can make
* a quick reuse from game to game as most sprite
* RAMs have 4 bytes per sprite, only the order
* and some bits differ

TARGET_SPRITE_Y = 2
TARGET_SPRITE_X = 3
TARGET_SPRITE_ATTRIBUTES = 1
TARGET_SPRITE_CODE = 0
TARGET_SPRITE_SIZEOF = 4




	.ifdef	RELEASE

OPT_ENABLE_LOGGING = 0           | DO NOT CHANGE THIS
